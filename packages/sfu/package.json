{
  "name": "@conclave/sfu",
  "version": "0.1.0",
  "description": "Mediasoup SFU for Conclave",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "scripts": {
    "predev": "node scripts/ensure-mediasoup-worker.mjs",
    "dev": "npx tsx server.ts",
    "prestart": "node scripts/ensure-mediasoup-worker.mjs",
    "start": "npx tsx server.ts",
    "email:dev": "react-email dev --dir server/email --port 3002",
    "new:game": "node ./scripts/new-game.mjs",
    "test:game-ai": "npx tsx scripts/test-game-ai.ts",
    "test": "vitest run test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@conclave/ui-tokens": "workspace:*",
    "@socket.io/redis-adapter": "^8.3.0",
    "chess.js": "^1.4.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mediasoup": "^3.20.10",
    "opusscript": "0.1.1",
    "posthog-node": "^5.39.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.5",
    "redis": "^6.0.1",
    "socket.io": "^4.8.3",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
