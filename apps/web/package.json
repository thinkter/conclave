{
  "name": "conclave-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "cf:build": "opennextjs-cloudflare build && node scripts/prune-open-next-og.mjs",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "pnpm run cf:build && pnpm run cf:deploy:direct",
    "cf:deploy:direct": "wrangler deploy --config wrangler.jsonc --domain conclave.acmvit.in --autoconfig false",
    "transcript:dev": "wrangler dev --config wrangler.transcript.jsonc --port 8788",
    "transcript:deploy": "wrangler deploy --config wrangler.transcript.jsonc",
    "transcript:typecheck": "tsc --noEmit -p transcript-worker/tsconfig.json",
    "test:unit": "vitest run --dir test",
    "start": "next start",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@conclave/apps-sdk": "workspace:*",
    "@conclave/meeting-core": "workspace:*",
    "@conclave/ui-tokens": "workspace:*",
    "@mediapipe/face_mesh": "0.4.1633559619",
    "@mediapipe/selfie_segmentation": "0.1.1675465747",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@tanstack/hotkeys": "^0.1.3",
    "@tanstack/react-hotkeys": "^0.1.3",
    "better-auth": "^1.6.22",
    "clsx": "^2.1.1",
    "facehash": "^0.1.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.548.0",
    "mediasoup-client": "3.20.0",
    "motion": "^12.42.0",
    "next": "^16.2.9",
    "openai": "^6.45.0",
    "posthog-js": "^1.395.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io-client": "^4.8.3",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "use-stick-to-bottom": "^1.1.6",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260628.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.62.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6",
    "wrangler": "^4.105.0"
  }
}
