{
  "name": "conclave-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "cf:build": "opennextjs-cloudflare build && node scripts/prune-open-next-og.mjs",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "pnpm run cf:build && pnpm run cf:deploy:direct",
    "cf:deploy:direct": "wrangler deploy .open-next/worker.js --assets .open-next/assets --name conclave-web --compatibility-date 2026-06-17 --compatibility-flag nodejs_compat --compatibility-flag global_fetch_strictly_public --domain conclave.acmvit.in --var BETTER_AUTH_URL:https://conclave.acmvit.in --var BETTER_AUTH_TRUSTED_ORIGINS:https://conclave.acmvit.in --var NEXT_PUBLIC_APP_URL:https://conclave.acmvit.in --var NEXT_PUBLIC_SITE_URL:https://conclave.acmvit.in --autoconfig false",
    "start": "next start",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@conclave/apps-sdk": "workspace:*",
    "@conclave/meeting-core": "workspace:*",
    "@conclave/ui-tokens": "workspace:*",
    "@mediapipe/face_mesh": "0.4.1633559619",
    "@mediapipe/selfie_segmentation": "0.1.1675465747",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@tanstack/react-hotkeys": "^0.1.3",
    "better-auth": "^1.6.22",
    "facehash": "^0.1.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.548.0",
    "mediasoup-client": "3.20.0",
    "next": "^16.2.9",
    "posthog-js": "^1.395.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.62.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.105.0"
  }
}
