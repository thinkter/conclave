require('dotenv')
Dotenv.load '../../Skip.env'

ios_bundle_identifier = ENV['PRODUCT_BUNDLE_IDENTIFIER'].to_s.strip
raise "PRODUCT_BUNDLE_IDENTIFIER must be set" if ios_bundle_identifier.empty?

app_identifier(ios_bundle_identifier)

