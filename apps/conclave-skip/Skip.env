// The configuration file for your Skip App (https://skip.tools).
// Properties specified here are shared between
// Darwin/Conclave.xcconfig and Android/settings.gradle.kts
// and will be included in the app's metadata files
// Info.plist and AndroidManifest.xml

// PRODUCT_NAME is the default title of the app, which must match the app's Swift module name
PRODUCT_NAME = Conclave

// PRODUCT_BUNDLE_IDENTIFIER is the unique id for both the iOS and Android app
PRODUCT_BUNDLE_IDENTIFIER = com.acmvit.conclave

// The semantic version of the app
MARKETING_VERSION = 2.0.0

// The build number specifying the internal app version
CURRENT_PROJECT_VERSION = 41

// The package name for the Android entry point, referenced by the AndroidManifest.xml
ANDROID_PACKAGE_NAME = conclave.module

// If your Android appId is different from the iOS Bundle Identifer, specify it here
// ANDROID_APPLICATION_ID = com.acmvit.conclave

SFU_JOIN_URL = https://conclave.acmvit.in/api/sfu/join
CONCLAVE_AUTH_BASE_URL = https://conclave.acmvit.in

// Public OAuth client IDs used by native Google Sign-In. The server still
// verifies ID tokens and owns the session cookie exchange.
GOOGLE_SIGN_IN_WEB_CLIENT_ID = 354185850500-sqientvdf0vr61ufogv8iii8ej81c9tr.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID = 354185850500-1gkdpp7t44asr02ac39j63fe57fn14if.apps.googleusercontent.com
GOOGLE_IOS_REVERSED_CLIENT_ID = com.googleusercontent.apps.354185850500-1gkdpp7t44asr02ac39j63fe57fn14if
