{
  "name": "conclave",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "workspaces": [
    "apps/*",
    "!apps/mobile",
    "packages/*"
  ],
  "scripts": {
    "debug:video-effects": "node scripts/debug-video-effects-headless.mjs",
    "debug:video-effects:face": "node scripts/debug-video-effects-face.mjs",
    "observe:meet-effects": "node scripts/observe-meet-effects-headless.mjs",
    "test": "pnpm -C packages/meeting-core test",
    "typecheck:web": "pnpm -C apps/web exec tsc --noEmit",
    "typecheck:sfu": "pnpm -C packages/sfu exec tsc --noEmit",
    "typecheck": "pnpm run typecheck:web && pnpm run typecheck:sfu"
  },
  "pnpm": {
    "overrides": {
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "minimatch@<3.1.4": ">=3.1.4",
      "tar@<=7.5.10": ">=7.5.13",
      "protobufjs": "^8.4.0",
      "kysely@<=0.28.13": ">=0.28.16",
      "kysely@<0.28.17": ">=0.28.17",
      "socket.io-parser@>=4.0.0 <4.2.6": ">=4.2.6",
      "brace-expansion@<1.1.13": "1.1.14",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "brace-expansion@>=4.0.0 <5.0.6": "5.0.6",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=3.0.0 <3.0.2": "3.0.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "yaml@>=2.0.0 <2.8.3": "2.8.3",
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.2",
      "defu@<=6.1.4": ">=6.1.7",
      "postcss@<8.5.10": ">=8.5.13",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1",
      "engine.io-client@<6.6.5": ">=6.6.5",
      "mediasoup-client": "3.20.0"
    }
  }
}
